OPENAI_BASE_URL=http://100.64.0.4:1234/v1
OPENAI_API_KEY=dummy
OPENAI_MODEL=google/gemma-4-31b
OPENAI_TIMEOUT=300
ROBOT_VLM_MODEL=google/gemma-4-31b
ROBOT_VLM_MAX_TOKENS=512
# Qwen prefill: it starts directly after the hidden thought block.
ROBOT_VLM_THINK_PREFILL="<think>\n\n</think>\n\n"
CAMERA_BASE_URL=http://127.0.0.1:8090
CAMERA_TIMEOUT=10
MODEL_KEEPALIVE_ENABLED=1
MODEL_KEEPALIVE_ON_STARTUP=1
MODEL_KEEPALIVE_INTERVAL=30
MODEL_KEEPALIVE_TIMEOUT=300
MODEL_KEEPALIVE_MAX_TOKENS=1
MODEL_KEEPALIVE_PROMPT=ok
VLA_ENABLED=0
VLA_COMMAND_URL=http://100.64.0.4:8080/command
VLA_TIMEOUT=120
VLA_STEP_DELAY=0.2
VLA_STOP_ON_ERROR=1
# Full pipeline: site -> VLM orchestrator -> resident SmolVLA runner.
# On the 4090 both services are local. For a laptop-only UI, use the 4090
# Tailscale address instead, for example http://100.64.0.1:8092.
ORCHESTRATOR_ENABLED=1
ORCHESTRATOR_URL=http://127.0.0.1:8092
ORCHESTRATOR_TIMEOUT=330
PLANNER_LOG_LEVEL=INFO
PLANNER_LOG_FILE=logs/planner.log
WEB_HOST=0.0.0.0
WEB_PORT=8000
