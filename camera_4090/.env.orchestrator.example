# VLM contract -> resident SmolVLA inference orchestrator.
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8092
ORCHESTRATOR_APPROVAL_TIMEOUT_SECONDS=300

# Per-step windows are deterministic: base time plus grace time. The VLM is
# called only after the window expires, never while a command is still active.
# Keep SUPERVISOR_MAX_ACTION_TIMEOUT_SECONDS <= SMOLVLA_ACTION_TIMEOUT_SECONDS.
SUPERVISOR_STEP_TIMEOUT=8
SUPERVISOR_GRASP_TIMEOUT_SECONDS=6
SUPERVISOR_MOVE_TIMEOUT_SECONDS=10
SUPERVISOR_PLACE_TIMEOUT_SECONDS=6
SUPERVISOR_ACTION_GRACE_SECONDS=3
SUPERVISOR_MAX_ACTION_TIMEOUT_SECONDS=15
SUPERVISOR_RUNNER_POLL_INTERVAL_SECONDS=0.5
SUPERVISOR_MAX_REPLANS=3
