# LeRobot rollout through camera_splitter/ZMQ.
# Copy to .env.lerobot_rollout and edit on the 4090.

LEROBOT_ROLLOUT_BIN=lerobot-rollout
LEROBOT_STRATEGY_TYPE=base

# Use rtc for SmolVLA/slow VLA models so actions keep flowing while policy computes chunks.
# Set to sync if your installed LeRobot build does not support rtc.
LEROBOT_INFERENCE_TYPE=rtc
LEROBOT_RTC_EXECUTION_HORIZON=10
LEROBOT_RTC_MAX_GUIDANCE_WEIGHT=10.0

LEROBOT_ROBOT_TYPE=so101_follower
LEROBOT_ROBOT_PORT=/dev/ttyACM0
LEROBOT_ROBOT_ID=my_follower_arm

LEROBOT_POLICY_PATH=outputs/train/my_smolvla/checkpoints/last/pretrained_model
LEROBOT_POLICY_DEVICE=cuda

LEROBOT_DURATION=60
LEROBOT_DISPLAY_DATA=true

# Keys are the names LeRobot/policy sees in robot.cameras.
# They must match the observation image keys used during training.
LEROBOT_CAMERA_FRONT_KEY=front
LEROBOT_CAMERA_WRIST_ENABLED=0
LEROBOT_CAMERA_WRIST_KEY=wrist

# Names are the camera_name values published by camera_splitter over ZMQ.
# They must match CAMERA_FRONT_NAME/CAMERA_WRIST_NAME in .env.camera.
LEROBOT_ZMQ_SERVER_ADDRESS=127.0.0.1
LEROBOT_ZMQ_PORT=5555
LEROBOT_CAMERA_FRONT_NAME=camera1
LEROBOT_CAMERA_WRIST_NAME=camera2

LEROBOT_CAMERA_WIDTH=640
LEROBOT_CAMERA_HEIGHT=480
LEROBOT_CAMERA_FPS=15

LEROBOT_DEFAULT_TASK=Pick up the red cube and place it in the box
