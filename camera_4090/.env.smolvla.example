# A local checkpoint path or a Hugging Face model ID.
# Directory that directly contains config.json for the fine-tuned policy.
# Example: /home/lab/Documents/lerobot/outputs/train/my_smolvla/checkpoints/last/pretrained_model
SMOLVLA_POLICY_PATH=/absolute/path/to/checkpoint/pretrained_model
# Leave as python to use this package's .venv, or set the absolute Python path
# for the existing LeRobot environment, for example /home/lab/miniconda3/envs/lerobot/bin/python.
SMOLVLA_PYTHON=python
SMOLVLA_DEVICE=cuda
SMOLVLA_USE_TORCH_COMPILE=0

# Descriptive compatibility settings. The runner never opens this port itself.
SMOLVLA_ROBOT_TYPE=so101_follower
SMOLVLA_ROBOT_PORT=/dev/ttyACM0
SMOLVLA_ROBOT_ID=robot_arm

# Resident inference settings. Keep queue size 1 so an old action is never queued.
SMOLVLA_RUNNER_FPS=15
SMOLVLA_ACTION_CHUNK_SIZE=0
SMOLVLA_ACTION_QUEUE_SIZE=1
SMOLVLA_ACTION_TIMEOUT_SECONDS=15
SMOLVLA_RUNNER_HOST=127.0.0.1
SMOLVLA_RUNNER_PORT=8091

# The resident runner loads the policy once and switches this task at runtime
# through POST /v1/actions/start. It reads camera frames itself and needs a
# fresh read-only robot state vector at POST /v1/state to run inference.
# It emits inference events only; it never opens the robot serial port.
SMOLVLA_INFERENCE_ENABLED=1
SMOLVLA_INFERENCE_FPS=15
SMOLVLA_STATE_TIMEOUT_MS=1000
SMOLVLA_ACTION_EVENT_INTERVAL=15

# Must exactly match the image keys and resolution from the fine-tuned policy.
SMOLVLA_CAMERA_HOST=127.0.0.1
SMOLVLA_CAMERA_PORT=5555
SMOLVLA_CAMERA_NAMES=camera1,camera2
SMOLVLA_CAMERA_WIDTH=640
SMOLVLA_CAMERA_HEIGHT=480
SMOLVLA_CAMERA_FPS=15
SMOLVLA_CAMERA_TIMEOUT_MS=5000
SMOLVLA_EVENT_LIMIT=200

# Supervisor -> runner connection.
SMOLVLA_RUNNER_URL=http://127.0.0.1:8091
SMOLVLA_RUNNER_TIMEOUT=10

# Supervisor policy after a visual check at each action deadline.
SUPERVISOR_STEP_TIMEOUT=8
SUPERVISOR_MAX_REPLANS=3
