CAMERA_FRONT_DEVICE=0
CAMERA_WRIST_DEVICE=1
# Must match the image keys used while training the SmolVLA policy.
CAMERA_FRONT_NAME=camera1
CAMERA_WRIST_NAME=camera2
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15
CAMERA_JPEG_QUALITY=82
CAMERA_HTTP_HOST=0.0.0.0
CAMERA_HTTP_PORT=8090
CAMERA_MOCK=0
CAMERA_ENABLE_ZMQ=1
CAMERA_ZMQ_BIND=tcp://0.0.0.0:5555
CAMERA_ZMQ_FPS=15
